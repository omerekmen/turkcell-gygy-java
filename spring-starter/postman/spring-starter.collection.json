{
  "info": {
    "name": "Spring Starter API",
    "description": "Collection for spring-starter endpoints using ApiResult responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "version", "value": "1" },
    { "key": "categoryId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "productId", "value": "77777777-7777-7777-7777-777777777777" },
    { "key": "tagId", "value": "44444444-4444-4444-4444-444444444444" },
    { "key": "userId", "value": "" },
    { "key": "exceptionLogId", "value": "" }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('Category id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.id).to.exist;",
                  "  pm.collectionVariables.set('categoryId', body.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Gaming Gear\"\n}" },
            "url": "{{baseUrl}}/api/v{{version}}/categories"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/categories"
          }
        },
        {
          "name": "Get Category By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Office Equipment\"\n}" },
            "url": "{{baseUrl}}/api/v{{version}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v{{version}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('Product id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.id).to.exist;",
                  "  pm.collectionVariables.set('productId', body.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"USB-C Dock\",\n  \"description\": \"Compact docking station with multiple ports\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"tagIds\": [\"{{tagId}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/products"
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/products"
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/products/{{productId}}"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"USB-C Dock Pro\",\n  \"description\": \"Updated docking station with more ports\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"tagIds\": [\"{{tagId}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v{{version}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Create Tag",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('Tag id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.id).to.exist;",
                  "  pm.collectionVariables.set('tagId', body.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Popular\"\n}" },
            "url": "{{baseUrl}}/api/v{{version}}/tags"
          }
        },
        {
          "name": "List Tags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/tags"
          }
        },
        {
          "name": "Get Tag By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/tags/{{tagId}}"
          }
        },
        {
          "name": "Update Tag",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Top Rated\"\n}" },
            "url": "{{baseUrl}}/api/v{{version}}/tags/{{tagId}}"
          }
        },
        {
          "name": "Delete Tag",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v{{version}}/tags/{{tagId}}"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/users"
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/users/login"
          }
        }
      ]
    },
    {
      "name": "Exception Logs",
      "item": [
        {
          "name": "Get Exception Log By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/exception-logs/{{exceptionLogId}}"
          }
        }
      ]
    }
  ]
}
