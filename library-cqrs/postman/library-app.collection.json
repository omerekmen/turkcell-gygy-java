    {
      "name": "Loans",
      "item": [
        {
          "name": "Create Loan",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('Loan id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.exist;",
                  "  pm.collectionVariables.set('loanId', body.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"staffId\": \"{{staffId}}\",\n  \"dueDate\": \"2027-01-31T12:00:00\",\n  \"bookCopyIds\": [\"{{bookCopyId1}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/loans"
          }
        },
        {
          "name": "Get Loan By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/loans/{{loanId}}"
          }
        },
        {
          "name": "List Loans",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/loans?page=0&size=20"
          }
        },
        {
          "name": "Filter Loans",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/loans?studentId={{studentId}}&status=ACTIVE&page=0&size=20"
          }
        },
        {
          "name": "Update Loan Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"OVERDUE\"\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/loans/{{loanId}}/status"
          }
        },
        {
          "name": "Return Loan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"processedByStaffId\": \"{{staffId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/loans/{{loanId}}/return"
          }
        },
        {
          "name": "Delete Loan",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v{{version}}/loans/{{loanId}}"
          }
        }
