{
  "info": {
    "name": "Library App API",
    "description": "Collection for library-app endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "version", "value": "1" },
    { "key": "categoryId", "value": "" },
    { "key": "bookId", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "staffId", "value": "" },
    { "key": "loanId", "value": "" },
    { "key": "reservationId", "value": "" },
    { "key": "studentUserId", "value": "" },
    { "key": "staffUserId", "value": "" },
    { "key": "publisherId", "value": "" },
    { "key": "authorId1", "value": "" },
    { "key": "authorId2", "value": "" },
    { "key": "bookCopyId1", "value": "" }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('Category id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.exist;",
                  "  pm.collectionVariables.set('categoryId', body.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Reference Books\"\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/categories"
          }
        },
        {
          "name": "Get Category By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/categories?page=0&size=20"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Reference & Encyclopedias\"\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v{{version}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 2xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "pm.test('Book id captured', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.exist;",
                  "  pm.collectionVariables.set('bookId', body.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Distributed Systems Patterns\",\n  \"isbn\": \"9781234567890\",\n  \"publisherId\": \"{{publisherId}}\",\n  \"publishedYear\": 2024,\n  \"categoryId\": \"{{categoryId}}\",\n  \"authorIds\": [\"{{authorId1}}\", \"{{authorId2}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/books"
          }
        },
        {
          "name": "Get Book By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/books/{{bookId}}"
          }
        },
        {
          "name": "List Books",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/books?page=0&size=20"
          }
        },
        {
          "name": "Search Books By Title",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v{{version}}/books?title=Clean&page=0&size=20"
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Distributed Systems Patterns - 2nd Edition\",\n  \"isbn\": \"9781234567890\",\n  \"publisherId\": \"{{publisherId}}\",\n  \"publishedYear\": 2025,\n  \"categoryId\": \"{{categoryId}}\",\n  \"authorIds\": [\"{{authorId1}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/v{{version}}/books/{{bookId}}"
          }
        },
        {
          "name": "Delete Book (Soft)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v{{version}}/books/{{bookId}}"
          }
        }
      ]
    },
